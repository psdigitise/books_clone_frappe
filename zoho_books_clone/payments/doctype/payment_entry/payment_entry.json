{
  "name": "Payment Entry",
  "module": "Payments",
  "doctype": "DocType",
  "is_submittable": 1,
  "track_changes": 1,
  "fields": [
    {
      "fieldname": "payment_type",
      "fieldtype": "Select",
      "label": "Payment Type",
      "options": "Receive\nPay\nInternal Transfer",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "payment_date",
      "fieldtype": "Date",
      "label": "Payment Date",
      "reqd": 1,
      "default": "Today",
      "in_list_view": 1
    },
    {
      "fieldname": "party_type",
      "fieldtype": "Select",
      "label": "Party Type",
      "options": "\nCustomer\nSupplier\nEmployee"
    },
    {
      "fieldname": "party",
      "fieldtype": "Dynamic Link",
      "label": "Party",
      "options": "party_type",
      "in_list_view": 1
    },
    {
      "fieldname": "party_name",
      "fieldtype": "Data",
      "label": "Party Name",
      "read_only": 1
    },
    {
      "fieldname": "paid_from",
      "fieldtype": "Link",
      "label": "Paid From",
      "options": "Account"
    },
    {
      "fieldname": "paid_to",
      "fieldtype": "Link",
      "label": "Paid To",
      "options": "Account"
    },
    {
      "fieldname": "paid_amount",
      "fieldtype": "Currency",
      "label": "Paid Amount",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "currency",
      "fieldtype": "Link",
      "label": "Currency",
      "options": "Currency",
      "default": "INR"
    },
    {
      "fieldname": "mode_of_payment",
      "fieldtype": "Link",
      "label": "Mode of Payment",
      "options": "Mode of Payment"
    },
    {
      "fieldname": "reference_no",
      "fieldtype": "Data",
      "label": "Reference / Cheque No"
    },
    {
      "fieldname": "reference_date",
      "fieldtype": "Date",
      "label": "Reference Date"
    },
    {
      "fieldname": "company",
      "fieldtype": "Link",
      "label": "Company",
      "options": "Company",
      "reqd": 1
    },
    {
      "fieldname": "references",
      "fieldtype": "Table",
      "label": "Invoice References",
      "options": "Payment Entry Reference"
    },
    {
      "fieldname": "remarks",
      "fieldtype": "Text",
      "label": "Remarks"
    }
  ],
  "permissions": [
    {
      "role": "Books Admin",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "submit": 1,
      "cancel": 1
    },
    {
      "role": "Accountant",
      "read": 1,
      "write": 1,
      "create": 1,
      "submit": 1,
      "cancel": 1
    },
    {
      "role": "Books Manager",
      "read": 1,
      "write": 1,
      "create": 1
    },
    {
      "role": "Books Viewer",
      "read": 1
    }
  ],
  "autoname": "naming_series:PAY-.YYYY.-.#####"
}