{
  "name": "Bank Account",
  "module": "Banking",
  "doctype": "DocType",
  "track_changes": 1,
  "fields": [
    {
      "fieldname": "account_name",
      "fieldtype": "Data",
      "label": "Account Name",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "bank_name",
      "fieldtype": "Data",
      "label": "Bank Name",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "account_number",
      "fieldtype": "Data",
      "label": "Account Number",
      "in_list_view": 1
    },
    {
      "fieldname": "ifsc_code",
      "fieldtype": "Data",
      "label": "IFSC Code"
    },
    {
      "fieldname": "account_type",
      "fieldtype": "Select",
      "label": "Account Type",
      "options": "Savings\nCurrent\nOverdraft\nCash\nCredit Card"
    },
    {
      "fieldname": "currency",
      "fieldtype": "Link",
      "label": "Currency",
      "options": "Currency",
      "default": "INR"
    },
    {
      "fieldname": "gl_account",
      "fieldtype": "Link",
      "label": "GL Account",
      "options": "Account"
    },
    {
      "fieldname": "company",
      "fieldtype": "Link",
      "label": "Company",
      "options": "Company",
      "reqd": 1
    },
    {
      "fieldname": "is_default",
      "fieldtype": "Check",
      "label": "Is Default"
    },
    {
      "fieldname": "opening_balance",
      "fieldtype": "Currency",
      "label": "Opening Balance"
    },
    {
      "fieldname": "current_balance",
      "fieldtype": "Currency",
      "label": "Current Balance",
      "read_only": 1
    }
  ],
  "permissions": [
    {
      "role": "Books Admin",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "Accountant",
      "read": 1,
      "write": 1,
      "create": 1
    },
    {
      "role": "Books Viewer",
      "read": 1
    }
  ],
  "autoname": "field:account_name"
}